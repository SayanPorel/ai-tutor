# Get your free Gemini API key from https://aistudio.google.com
# Each user enters their own key in the app UI — you never need to set this
GEMINI_API_KEY=your_gemini_api_key_here

# Random secret for NextAuth — generate one at https://generate-secret.vercel.app
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000